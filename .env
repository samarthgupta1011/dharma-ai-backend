# ══════════════════════════════════════════════════════════════════════════════
#  Dharma AI Backend — Local Environment Configuration
#  ──────────────────────────────────────────────────────────
#  This is a LOCAL COPY for development. Never commit this file to git.
#  To set up: cp .env.example .env (then optionally edit values)
#
#  For configuration reference, see .env.example and README.md Section 5.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=local
APP_NAME="Dharma AI Backend"
APP_VERSION=1.0.0
DEBUG=true

# ── Database (Local MongoDB via docker-compose) ───────────────────────────────
DATABASE_NAME=dharma_db
MONGODB_URL=mongodb://localhost:27017

# ── JWT ───────────────────────────────────────────────────────────────────────
# Development key (weak — DO NOT use in production).
# In production, this is fetched from Azure Key Vault.
JWT_SECRET_KEY=change-me-before-deploying-must-be-32-chars-minimum
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Azure Services (Ignored in local mode) ────────────────────────────────────
# These are not used when APP_ENV=local, but included for reference.
AZURE_KEY_VAULT_URL=https://dharma-kv.vault.azure.net/
COSMOS_DB_SECRET_NAME=cosmos-db-connection-string
JWT_SECRET_NAME=jwt-secret-key

# Keeping these empty disables the storage service in local mode, which is fine for development without media.
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local development: allow all origins. Tighten in production.
ALLOWED_ORIGINS=["*"]

