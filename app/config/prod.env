# ══════════════════════════════════════════════════════════════════════════════
#  Dharma AI Backend — Production Environment File
#  ──────────────────────────────────────────────────────────────────────────────
#  Used by Azure Container Apps (APP_ENV=production).
#  This file is SAFE to commit to git — it contains NO SECRETS.
#
#  Sensitive secrets (Cosmos DB connection string, JWT key) are stored in
#  Azure Key Vault and fetched at runtime by the app using Managed Identity.
#
#  How to deploy:
#    IMAGE_TAG=$(git rev-parse --short HEAD)-$(date +%s)
#    az acr build --registry dharmacr --platform linux/amd64 --image dharma-api:${IMAGE_TAG} .
#    ENV_VARS=$(grep -v '^#' app/config/prod.env | grep -v '^$')
#    UMSI_CLIENT_ID=$(az identity show --name dharma-env-umsi --resource-group dharma-rg --query clientId -o tsv)
#    az containerapp update --name dharma-api --resource-group dharma-rg --image dharmacr.azurecr.io/dharma-api:${IMAGE_TAG} --set-env-vars $(echo "${ENV_VARS}" | tr '\n' ' ') AZURE_CLIENT_ID=${UMSI_CLIENT_ID}
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=Dharma-AI-Backend
APP_VERSION=1.0.0
DEBUG=false

# ── Database (Azure Cosmos DB) ────────────────────────────────────────────────
# In production, the actual connection string is fetched from Azure Key Vault.
# This variable only specifies the KEY VAULT SECRET NAME, not the connection string.
DATABASE_NAME=dharma_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# The actual JWT signing key is fetched from Azure Key Vault at startup.
# This variable only specifies the KEY VAULT SECRET NAME.
JWT_SECRET_NAME=jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Azure Key Vault (Production Secrets) ──────────────────────────────────────
# Cosmos DB connection string is stored here with this name.
# JWT signing key is stored here with this name.
# The Container App's Managed Identity must have "Key Vault Secrets User" role.
AZURE_KEY_VAULT_URL=https://dharma-kv.vault.azure.net/
COSMOS_DB_SECRET_NAME=cosmos-db-connection-string

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_URL=https://dharmastorageacc.blob.core.windows.net
AZURE_STORAGE_CONTAINER=dharma-content
AZURE_STORAGE_SAS_EXPIRY_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: restrict to known domains. Update with your actual domains.
ALLOWED_ORIGINS=["https://dharma-app.example.com"]

# ── Note: AZURE_CLIENT_ID ─────────────────────────────────────────────────────
# NOT included here because it's instance-specific (ties to UMSI in a resource group).
# Set it separately when deploying:
#   --set-env-vars AZURE_CLIENT_ID=$(az identity show --name dharma-env-umsi --query clientId -o tsv)

# Open AI settings
OPENAI_API_KEY_SECRET_NAME=openai-api-key
ENABLE_OPENAI=true