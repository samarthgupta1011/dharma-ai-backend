# ══════════════════════════════════════════════════════════════════════════════
#  Dharma AI Backend — Environment Variable Reference
#  ──────────────────────────────────────────────────────────────
#  This is a REFERENCE file showing all available environment variables.
#  DO NOT copy this file directly.
#
#  FOR LOCAL DEVELOPMENT:
#    Copy or link dev.env to .env:
#      cp dev.env .env
#    Then use:
#      docker-compose up
#
#  FOR PRODUCTION:
#    Use prod.env (it is safe to commit to git — contains no secrets).
#    Deploy with Azure Container Apps:
#      az containerapp update ... --env-vars-from-file prod.env
#
#  Full documentation: See README.md "Section 5: Environment Variables & Configuration"
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (dev.env)
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=local                                   # "local" | "production"
APP_NAME="Dharma AI Backend"
APP_VERSION=1.0.0
DEBUG=true

# Database (Local MongoDB)
DATABASE_NAME=dharma_db
MONGODB_URL=mongodb://localhost:27017

# JWT (development key — weak)
JWT_SECRET_KEY=change-me-before-deploying-must-be-32-chars-minimum
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080           # 7 days

# Azure Services (ignored in local mode)
AZURE_KEY_VAULT_URL=https://dharma-kv.vault.azure.net/
COSMOS_DB_SECRET_NAME=cosmos-db-connection-string
JWT_SECRET_NAME=jwt-secret-key
AZURE_STORAGE_ACCOUNT_URL=https://dharmastorage.blob.core.windows.net
AZURE_STORAGE_CONTAINER=dharma-media
AZURE_STORAGE_SAS_EXPIRY_MINUTES=60

# CORS (permissive in dev)
ALLOWED_ORIGINS=["*"]

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (prod.env + Azure Key Vault)
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=production
DEBUG=false

# Database (Azure Cosmos DB — connection string fetched from AKV)
DATABASE_NAME=dharma_db

# JWT (signing key fetched from AKV)
JWT_SECRET_NAME=jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Azure Key Vault (where secrets are stored)
AZURE_KEY_VAULT_URL=https://dharma-kv.vault.azure.net/
COSMOS_DB_SECRET_NAME=cosmos-db-connection-string

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_URL=https://dharmastorage.blob.core.windows.net
AZURE_STORAGE_CONTAINER=dharma-media

# CORS (restricted in prod)
ALLOWED_ORIGINS=["https://dharma-app.example.com"]

# NOTE: AZURE_CLIENT_ID is NOT in prod.env
#       It is instance-specific (points to the UMSI) and set separately:
#         --set-env-vars AZURE_CLIENT_ID=$(az identity show --name dharma-env-umsi --query clientId -o tsv)
AZURE_CLIENT_ID=

# ── Azure Key Vault [PROD ONLY] ───────────────────────────────────────────────
# The UMSI must have "Key Vault Secrets User" role on the Key Vault.
AZURE_KEY_VAULT_URL=https://your-keyvault-name.vault.azure.net/
COSMOS_DB_SECRET_NAME=cosmos-db-connection-string

# ── Azure Blob Storage [PROD ONLY] ────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_URL=https://yourstorageaccount.blob.core.windows.net
AZURE_STORAGE_CONTAINER=dharma-media
AZURE_STORAGE_SAS_EXPIRY_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Use ["*"] only in development.  In production, list explicit origins:
# ALLOWED_ORIGINS=["https://dharma-ai.app","https://staging.dharma-ai.app"]
ALLOWED_ORIGINS=["*"]
