# ══════════════════════════════════════════════════════════════════════════════
#  Dharma AI Backend — Environment Variable Reference
#  ─────────────────────────────────────────────────
#  Copy this file to `.env` and fill in your values for local development.
#  NEVER commit `.env` to source control.
#
#  Variables marked [LOCAL ONLY] are ignored when APP_ENV=production.
#  Variables marked [PROD ONLY]  are only required when APP_ENV=production.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=local                           # "local" | "production"
APP_NAME="Dharma AI Backend"
APP_VERSION=1.0.0
DEBUG=true

# ── Database [LOCAL ONLY] ─────────────────────────────────────────────────────
# In production, the connection string is fetched from Azure Key Vault.
#
# Locally we use MongoDB 6.0 (via docker-compose) which is wire-protocol
# compatible with Azure Cosmos DB API for MongoDB v6.0.
#
# Note: The Cosmos DB Linux emulator is architecturally incompatible with
# Apple Silicon Macs (jemalloc / QEMU virtual address layout mismatch).
# See: github.com/microsoft/azure-cosmos-db-emulator-docker/issues/45
#
# ⚠️  docker-compose.yml overrides this with mongodb://mongo:27017 (Docker DNS).
#     This value is only used when running the API or seed script bare-metal.
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=dharma_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters.  Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-before-deploying-must-be-32-chars-minimum
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── Azure Managed Identity [PROD ONLY] ───────────────────────────────────────
# Required when using a user-assigned managed identity (UMSI).
# DefaultAzureCredential cannot resolve which UMSI to use without this —
# omitting it causes "invalid_scope" / ClientAuthenticationError at startup.
#
# Retrieve with:
#   az identity show --name dharma-env-umsi --resource-group dharma-rg \
#     --query clientId -o tsv
#
# Set on the Container App:
#   az containerapp update --name <app> --resource-group <rg> \
#     --set-env-vars AZURE_CLIENT_ID=<client-id>
AZURE_CLIENT_ID=

# ── Azure Key Vault [PROD ONLY] ───────────────────────────────────────────────
# The UMSI must have "Key Vault Secrets User" role on the Key Vault.
AZURE_KEY_VAULT_URL=https://your-keyvault-name.vault.azure.net/
COSMOS_DB_SECRET_NAME=cosmos-db-connection-string

# ── Azure Blob Storage [PROD ONLY] ────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_URL=https://yourstorageaccount.blob.core.windows.net
AZURE_STORAGE_CONTAINER=dharma-media

# ── CORS ──────────────────────────────────────────────────────────────────────
# Use ["*"] only in development.  In production, list explicit origins:
# ALLOWED_ORIGINS=["https://dharma-ai.app","https://staging.dharma-ai.app"]
ALLOWED_ORIGINS=["*"]
